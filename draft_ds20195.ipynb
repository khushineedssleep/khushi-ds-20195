   "source": [
    "mental = places[places[\"measureid\"].isin([\"MHLTH\", \"DEPRESSION\"])].copy()\n",
    "\n",
    "mental[\"county_fips\"] = mental[\"locationid\"].astype(str).str.zfill(5)\n",
    "mental[\"data_value\"] = pd.to_numeric(mental[\"data_value\"], errors=\"coerce\")\n",
    "\n",
    "mental_small = mental[\n",
    "    [\"county_fips\", \"stateabbr\", \"statedesc\", \"locationname\",\n",
    "     \"measureid\", \"measure\", \"data_value\"]\n",
    "]\n",
    "\n",
    "mental_wide = (\n",
    "    mental_small\n",
    "    .pivot_table(\n",
    "        index=[\"county_fips\", \"stateabbr\", \"statedesc\", \"locationname\"],\n",
    "        columns=\"measureid\",\n",
    "        values=\"data_value\",\n",
    "        aggfunc=\"first\"\n",
    "    )\n",
    "    .reset_index()\n",
    ")\n",
    "\n",
    "mental_wide = mental_wide.rename(columns={\n",
    "    \"MHLTH\": \"poor_mental_health_pct\",\n",
    "    \"DEPRESSION\": \"depression_pct\"\n",
    "})\n",
    "\n",
    "mental_wide.head()"
   ]
