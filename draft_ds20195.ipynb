    "num_cols = [\n",
    "    \"total_pop\",\n",
    "    \"median_income\",\n",
    "    \"poverty_denom\",\n",
    "    \"poverty_count\",\n",
    "    \"labor_force\",\n",
    "    \"unemployed\",\n",
    "    \"race_total\",\n",
    "    \"nh_white\",\n",
    "    \"nh_black\",\n",
    "    \"hispanic\"\n",
    "]\n",
    "\n",
    "for col in num_cols:\n",
    "    acs[col] = pd.to_numeric(acs[col], errors=\"coerce\")\n",
    "\n",
    "acs[\"poverty_rate\"] = 100 * acs[\"poverty_count\"] / acs[\"poverty_denom\"]\n",
    "acs[\"unemployment_rate\"] = 100 * acs[\"unemployed\"] / acs[\"labor_force\"]\n",
    "acs[\"pct_nh_white\"] = 100 * acs[\"nh_white\"] / acs[\"race_total\"]\n",
    "acs[\"pct_nh_black\"] = 100 * acs[\"nh_black\"] / acs[\"race_total\"]\n",
    "acs[\"pct_hispanic\"] = 100 * acs[\"hispanic\"] / acs[\"race_total\"]\n",
    "\n",
    "acs_context = acs[\n",
    "    [\n",
    "        \"county_fips\",\n",
    "        \"county_name\",\n",
    "        \"total_pop\",\n",
    "        \"median_income\",\n",
    "        \"poverty_rate\",\n",
    "        \"unemployment_rate\",\n",
    "        \"pct_nh_white\",\n",
    "        \"pct_nh_black\",\n",
    "        \"pct_hispanic\"\n",
    "    ]\n",
    "].copy()\n",
    "\n",
    "acs_context.head()"
   ]
