   "source": [
    "def zscore(x):\n",
    "    return (x - x.mean()) / x.std()\n",
    "\n",
    "state_df[\"z_need\"] = zscore(state_df[\"poor_mental_health_pct\"])\n",
    "state_df[\"z_capacity\"] = zscore(state_df[\"mental_health_facilities\"])\n",
    "\n",
    "state_df[\"need_capacity_mismatch\"] = state_df[\"z_need\"] - state_df[\"z_capacity\"]\n",
    "\n",
    "state_df.sort_values(\"need_capacity_mismatch\", ascending=False).head(10)"
   ]
  },
